# Anthropic API Configuration
ANTHROPIC_API_KEY=your_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Browser Configuration
BROWSER_HEADLESS=false
BROWSER_TIMEOUT=30000
BROWSER_VIEWPORT_WIDTH=1920
BROWSER_VIEWPORT_HEIGHT=1080

# Agent Configuration
MAX_EXPLORATION_DEPTH=5
NAVIGATION_DELAY=1.0
MAX_PARALLEL_ANALYSES=3
CONFIDENCE_THRESHOLD_DEFAULT=0.7

# Storage Configuration
SESSION_DB_PATH=./data/sessions/sessions.db
SCREENSHOT_DIR=./data/sessions/screenshots
DOM_SNAPSHOT_DIR=./data/sessions/dom_snapshots

# Web Interface Configuration
WEB_HOST=0.0.0.0
WEB_PORT=8000
WEB_RELOAD=false
WEB_LOG_LEVEL=info

# Framework Configuration
ENABLE_IEEE_7010=true
ENABLE_DSA_ARTICLE_28=true
ENABLE_ATTENTION_ECONOMY=true
ENABLE_ICO_AADC=true

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=./logs/agent.log

# Performance Configuration
MAX_SCREENSHOT_SIZE_MB=10
MAX_DOM_SNAPSHOT_SIZE_KB=500
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600

# Development Configuration
DEBUG=false
ENABLE_TELEMETRY=false
SAVE_INTERMEDIATE_STATES=true
