# iPhone Compliance Agent - Environment Configuration

# ============================================================================
# REQUIRED: AI API Keys
# ============================================================================

# Anthropic API Key (for Claude Vision analysis)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Alternative: OpenAI API Key (if using GPT-4 Vision instead)
# OPENAI_API_KEY=your_openai_api_key_here


# ============================================================================
# iOS Emulator Configuration
# ============================================================================

# Appium Server URL
APPIUM_SERVER=http://localhost:4723

# iOS Platform Version (match your Xcode simulator)
IOS_PLATFORM_VERSION=17.0

# iOS Device Name (available in Xcode > Window > Devices and Simulators)
IOS_DEVICE_NAME=iPhone 15 Pro

# Appium Command Timeout (seconds)
APPIUM_TIMEOUT=300


# ============================================================================
# Optional: Client & Business Configuration
# ============================================================================

# Default client name for reports
DEFAULT_CLIENT_NAME=Demo Client

# Billing rate (dollars per hour)
HOURLY_RATE=350

# Reports output directory
REPORTS_DIR=law/iphone_compliance_agent/reports

# Screenshots output directory
SCREENSHOTS_DIR=law/iphone_compliance_agent/reports/screenshots


# ============================================================================
# Optional: Integration Settings
# ============================================================================

# Practice Management System API
# PMS_API_URL=https://api.clio.com
# PMS_API_KEY=your_pms_api_key

# Document Management System
# DMS_API_URL=https://api.netdocuments.com
# DMS_API_KEY=your_dms_api_key

# Email Service
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your_email@example.com
# SMTP_PASSWORD=your_email_password


# ============================================================================
# Optional: Development Settings
# ============================================================================

# Debug mode (more verbose logging)
DEBUG=false

# Save raw API responses
SAVE_RAW_RESPONSES=false

# Maximum screenshots per test
MAX_SCREENSHOTS=50

# Test mode (skip actual emulator, use simulated data)
TEST_MODE=true
