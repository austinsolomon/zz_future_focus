# Tier 3 - GTM Lead Research Agent - Environment Variables

# ============================================================================
# LLM Configuration
# ============================================================================

# OpenAI API key (required)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Model selection (gpt-4o-mini recommended for cost/performance balance)
OPENAI_MODEL=gpt-4o-mini

# ============================================================================
# Production Tool Integrations (Optional - agent uses mock data if not set)
# ============================================================================

# Serper API for web search (https://serper.dev)
# SERPER_API_KEY=your_serper_api_key_here

# Proxycurl for LinkedIn data (https://nubela.co/proxycurl)
# PROXYCURL_API_KEY=your_proxycurl_api_key_here

# Clearbit for company enrichment (https://clearbit.com)
# CLEARBIT_API_KEY=your_clearbit_api_key_here

# Apollo.io for prospect data (https://apollo.io)
# APOLLO_API_KEY=your_apollo_api_key_here

# ZoomInfo API (https://www.zoominfo.com)
# ZOOMINFO_API_KEY=your_zoominfo_api_key_here

# ============================================================================
# API Server Configuration
# ============================================================================

# Server port (default: 8000)
PORT=8000

# Allowed origins for CORS (comma-separated)
CORS_ORIGINS=https://your-n8n-instance.com,http://localhost:5678

# API authentication token (for securing the /research endpoint)
API_AUTH_TOKEN=your-secure-random-token-here

# ============================================================================
# Monitoring & Logging
# ============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Sentry DSN for error tracking (optional)
# SENTRY_DSN=https://your-sentry-dsn-here

# ============================================================================
# Rate Limiting & Caching
# ============================================================================

# Redis URL for caching research results (optional)
# REDIS_URL=redis://localhost:6379/0

# Cache TTL in seconds (default: 24 hours)
# CACHE_TTL=86400

# Rate limit: max requests per minute
# RATE_LIMIT_PER_MINUTE=10
