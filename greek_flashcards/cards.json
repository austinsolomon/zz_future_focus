    {"id":"n-decline-child","category":"noun_declension","difficulty":4,"concept":"Noun — Decline 'the child' (n.)","en":["the child (nom.)","of the child","the child (acc.)","the children (nom. pl.)","of the children","the children (acc. pl.)"],"gr":["το παιδί","του παιδιού","το παιδί","τα παιδιά","των παιδιών","τα παιδιά"],"phon":["to paidi","tou paidiou","to paidi","ta paidia","ton paidion","ta paidia"],"notes":"Neuter -ί declension. Same pattern as το σπίτι.","tags":["nouns","declension","neuter"]},

    {"id":"n-decline-man","category":"noun_declension","difficulty":5,"concept":"Noun — Decline 'the man' (m., irregular)","en":["the man (nom.)","of the man","the man (acc.)","the men (nom. pl.)","of the men","the men (acc. pl.)"],"gr":["ο άνδρας","του άνδρα","τον άνδρα","οι άνδρες","των ανδρών","τους άνδρες"],"phon":["o andras","tou andra","ton andra","i andres","ton andron","tous andres"],"notes":"-ας ending masculine. Genitive plural stress shifts to ending.","tags":["nouns","declension","masculine","irregular"]},
    {"id":"n-decline-woman","category":"noun_declension","difficulty":5,"concept":"Noun — Decline 'the woman' (f., irregular)","en":["the woman (nom.)","of the woman","the woman (acc.)","the women (nom. pl.)","of the women","the women (acc. pl.)"],"gr":["η γυναίκα","της γυναίκας","τη γυναίκα","οι γυναίκες","των γυναικών","τις γυναίκες"],"phon":["i gynaika","tis gynaikas","ti gynaika","i gynaikes","ton gynaikon","tis gynaikes"],"notes":"Feminine -α. Genitive plural stress shifts: γυναικών.","tags":["nouns","declension","feminine","irregular"]},
    {"id":"n-vocative","category":"noun_declension","difficulty":5,"concept":"Noun — Vocative (friend!)","en":["friend! (calling out)"],"gr":["φίλε!"],"phon":["file!"],"notes":"VOCATIVE case for direct address. ο φίλος → φίλε! (drop the -ς, change vowel).","tags":["nouns","case","vocative"]},
    {"id":"n-poss-my","category":"noun_declension","difficulty":5,"concept":"Noun — my friend","en":["my friend"],"gr":["ο φίλος μου"],"phon":["o filos mou"],"notes":"Possessive μου AFTER the noun. Greek possessives are weak pronouns attached to the noun phrase.","tags":["nouns","possessive"]},
    {"id":"n-poss-your","category":"noun_declension","difficulty":5,"concept":"Noun — your friend","en":["your friend"],"gr":["ο φίλος σου"],"phon":["o filos sou"],"notes":"Possessive σου (informal, singular) AFTER the noun.","tags":["nouns","possessive"]},

    {"id":"e-good-morning","category":"everyday_situations","difficulty":1,"concept":"Greeting — Good morning","en":["Good morning."],"gr":["Καλημέρα."],"phon":["Kalimera."],"notes":"Used until early afternoon. Καλη- (good) + μέρα (day).","tags":["greetings"]},
    {"id":"e-good-evening","category":"everyday_situations","difficulty":1,"concept":"Greeting — Good evening","en":["Good evening."],"gr":["Καλησπέρα."],"phon":["Kalispera."],"notes":"Used afternoon onwards.","tags":["greetings"]},
    {"id":"e-good-night","category":"everyday_situations","difficulty":1,"concept":"Greeting — Good night","en":["Good night."],"gr":["Καληνύχτα."],"phon":["Kalinihta."],"notes":"Said when parting at night / before sleep.","tags":["greetings"]},
    {"id":"e-hi-info","category":"everyday_situations","difficulty":1,"concept":"Greeting — Hi (informal)","en":["Hi (informal)."],"gr":["Γεια σου."],"phon":["Yia sou."],"notes":"Lit. 'health to you.' Singular / informal.","tags":["greetings","informal"]},
    {"id":"e-hi-form","category":"everyday_situations","difficulty":1,"concept":"Greeting — Hi (formal/plural)","en":["Hi (formal / plural)."],"gr":["Γεια σας."],"phon":["Yia sas."],"notes":"Formal singular OR plural.","tags":["greetings","formal"]},
    {"id":"e-please","category":"everyday_situations","difficulty":1,"concept":"Politeness — Please / You're welcome","en":["please / you're welcome"],"gr":["Παρακαλώ"],"phon":["Parakalo"],"notes":"Multi-purpose: please, you're welcome, come in, can I help you?","tags":["politeness"]},
    {"id":"e-thanks","category":"everyday_situations","difficulty":1,"concept":"Politeness — Thank you","en":["thank you"],"gr":["Ευχαριστώ"],"phon":["Efharisto"],"notes":"Ευχαριστώ πολύ = thank you very much.","tags":["politeness"]},
    {"id":"e-sorry","category":"everyday_situations","difficulty":1,"concept":"Politeness — Excuse me / Sorry","en":["Excuse me. / Sorry."],"gr":["Συγγνώμη."],"phon":["Signomi."],"notes":"All-purpose: excuse me, sorry, pardon. Also Συγγνώμη; with a question intonation = pardon?","tags":["politeness"]},
    {"id":"e-bye","category":"everyday_situations","difficulty":1,"concept":"Greeting — Goodbye","en":["Goodbye."],"gr":["Αντίο."],"phon":["Andio."],"notes":"Formal goodbye. Γεια σου is also used informally.","tags":["greetings"]},
    {"id":"e-cheers","category":"everyday_situations","difficulty":1,"concept":"Toast — Cheers!","en":["Cheers!"],"gr":["Στην υγειά μας!"],"phon":["Stin iyia mas!"],"notes":"Lit. 'to our health.' Shorter: Γεια μας!","tags":["toast"]},

    {"id":"e-how-are-you","category":"everyday_situations","difficulty":2,"concept":"Small talk — How are you?","en":["How are you? (informal)"],"gr":["Τι κάνεις;"],"phon":["Ti kaneis?"],"notes":"Informal. Formal/plural: Τι κάνετε;","tags":["small-talk","informal"]},
    {"id":"e-fine","category":"everyday_situations","difficulty":2,"concept":"Small talk — Fine, thanks","en":["Fine, thanks."],"gr":["Καλά, ευχαριστώ."],"phon":["Kala, efharisto."],"notes":"Standard response to Τι κάνεις;","tags":["small-talk"]},
    {"id":"e-name-q","category":"everyday_situations","difficulty":2,"concept":"Small talk — What's your name?","en":["What's your name? (informal)"],"gr":["Πώς σε λένε;"],"phon":["Pos se lene?"],"notes":"Lit. 'How do they call you?' Formal: Πώς σας λένε;","tags":["small-talk","question"]},
    {"id":"e-name-a","category":"everyday_situations","difficulty":2,"concept":"Small talk — My name is…","en":["My name is…"],"gr":["Με λένε…"],"phon":["Me lene…"],"notes":"Lit. 'They call me…'. Με λένε Γιάννη = My name is Yiannis.","tags":["small-talk","intro"]},
    {"id":"e-nice-meet","category":"everyday_situations","difficulty":2,"concept":"Small talk — Nice to meet you","en":["Nice to meet you."],"gr":["Χαίρω πολύ."],"phon":["Hero poli."],"notes":"Lit. 'I rejoice greatly.' Said upon being introduced.","tags":["small-talk","intro"]},
    {"id":"e-from-q","category":"everyday_situations","difficulty":2,"concept":"Small talk — Where are you from?","en":["Where are you from?"],"gr":["Από πού είσαι;"],"phon":["Apo pou eisai?"],"notes":"από + πού + είσαι = from + where + you-are.","tags":["small-talk","question"]},
    {"id":"e-from-usa","category":"everyday_situations","difficulty":2,"concept":"Small talk — I'm from America","en":["I'm from America."],"gr":["Είμαι από την Αμερική."],"phon":["Eimai apo tin Ameriki."],"notes":"από + accusative (την). Other countries: από την Αγγλία (England), από τον Καναδά (Canada).","tags":["small-talk","intro"]},
    {"id":"e-coffee-please","category":"everyday_situations","difficulty":2,"concept":"Café — A coffee, please","en":["A coffee, please."],"gr":["Έναν καφέ, παρακαλώ."],"phon":["Enan kafe, parakalo."],"notes":"Έναν is accusative masc. of one (έναν / μία / ένα).","tags":["cafe","ordering"]},
    {"id":"e-water-please","category":"everyday_situations","difficulty":2,"concept":"Café — Water, please","en":["Water, please."],"gr":["Νερό, παρακαλώ."],"phon":["Nero, parakalo."],"notes":"Often add Ένα μπουκάλι νερό = a bottle of water.","tags":["cafe","ordering"]},
    {"id":"e-bill-please","category":"everyday_situations","difficulty":2,"concept":"Café — The bill, please","en":["The bill, please."],"gr":["Τον λογαριασμό, παρακαλώ."],"phon":["Ton logariasmo, parakalo."],"notes":"Accusative of ο λογαριασμός.","tags":["cafe","payment"]},

    {"id":"e-how-much","category":"everyday_situations","difficulty":3,"concept":"Shopping — How much?","en":["How much does it cost?"],"gr":["Πόσο κοστίζει;"],"phon":["Poso kostizei?"],"notes":"Also: Πόσο κάνει; (very common in markets).","tags":["shopping","question"]},
    {"id":"e-where-bath","category":"everyday_situations","difficulty":3,"concept":"Directions — Where is the bathroom?","en":["Where is the bathroom?"],"gr":["Πού είναι η τουαλέτα;"],"phon":["Pou einai i toualeta?"],"notes":"Universal travel essential.","tags":["directions","question"]},
    {"id":"e-do-you-have","category":"everyday_situations","difficulty":3,"concept":"Shopping — Do you have…?","en":["Do you have…?"],"gr":["Έχετε…;"],"phon":["Ehete…?"],"notes":"Polite/plural form of έχω. Έχετε αυτό σε άλλο χρώμα; = Do you have this in another color?","tags":["shopping","question"]},
    {"id":"e-expensive","category":"everyday_situations","difficulty":3,"concept":"Shopping — It's too expensive","en":["It's too expensive."],"gr":["Είναι πολύ ακριβό."],"phon":["Einai poli akrivo."],"notes":"Useful for bargaining. Cheap = φθηνό.","tags":["shopping"]},
    {"id":"e-looking-for","category":"everyday_situations","difficulty":3,"concept":"Shopping — I'm looking for…","en":["I'm looking for…"],"gr":["Ψάχνω για…"],"phon":["Psahno gia…"],"notes":"ψάχνω = search/look for.","tags":["shopping"]},
    {"id":"e-turn-left","category":"everyday_situations","difficulty":3,"concept":"Directions — Turn left","en":["Turn left."],"gr":["Στρίψε αριστερά."],"phon":["Stripse aristera."],"notes":"Imperative of στρίβω = turn.","tags":["directions"]},
    {"id":"e-turn-right","category":"everyday_situations","difficulty":3,"concept":"Directions — Turn right","en":["Turn right."],"gr":["Στρίψε δεξιά."],"phon":["Stripse dexia."],"notes":"Imperative of στρίβω = turn.","tags":["directions"]},
    {"id":"e-straight","category":"everyday_situations","difficulty":3,"concept":"Directions — Straight ahead","en":["Straight ahead."],"gr":["Ευθεία."],"phon":["Efthia."],"notes":"Or πάνε ευθεία = go straight.","tags":["directions"]},
    {"id":"e-bus-stop","category":"everyday_situations","difficulty":3,"concept":"Travel — Where is the bus stop?","en":["Where is the bus stop?"],"gr":["Πού είναι η στάση;"],"phon":["Pou einai i stasi?"],"notes":"η στάση = stop. Specifically: η στάση του λεωφορείου = bus stop.","tags":["travel","question"]},
    {"id":"e-today","category":"everyday_situations","difficulty":3,"concept":"Time — Today","en":["today"],"gr":["σήμερα"],"phon":["simera"],"notes":"σήμερα = today. Compare εχθές (yesterday) and αύριο (tomorrow).","tags":["time"]},

    {"id":"e-tomorrow","category":"everyday_situations","difficulty":4,"concept":"Time — Tomorrow","en":["tomorrow"],"gr":["αύριο"],"phon":["avrio"],"notes":"αύριο = tomorrow.","tags":["time"]},
    {"id":"e-now","category":"everyday_situations","difficulty":4,"concept":"Time — Now","en":["now"],"gr":["τώρα"],"phon":["tora"],"notes":"τώρα = now / at this moment.","tags":["time"]},
    {"id":"e-what-time","category":"everyday_situations","difficulty":4,"concept":"Time — What time is it?","en":["What time is it?"],"gr":["Τι ώρα είναι;"],"phon":["Ti ora einai?"],"notes":"η ώρα = hour / time. Είναι τρεις = it's three.","tags":["time","question"]},
    {"id":"e-slower","category":"everyday_situations","difficulty":4,"concept":"Communication — Slower, please","en":["Slower, please."],"gr":["Πιο αργά, παρακαλώ."],"phon":["Pio arga, parakalo."],"notes":"πιο = more (comparative marker). αργά = slowly.","tags":["communication","politeness"]},
    {"id":"e-english","category":"everyday_situations","difficulty":4,"concept":"Communication — Do you speak English?","en":["Do you speak English?"],"gr":["Μιλάς αγγλικά;"],"phon":["Milas anglika?"],"notes":"Formal: Μιλάτε αγγλικά;","tags":["communication","question"]},

    {"id":"e-help","category":"everyday_situations","difficulty":5,"concept":"Emergency — Help!","en":["Help!"],"gr":["Βοήθεια!"],"phon":["Voithia!"],"notes":"Universal emergency cry. βοηθάω = to help (verb).","tags":["emergency"]},
    {"id":"e-doctor","category":"everyday_situations","difficulty":5,"concept":"Emergency — I need a doctor","en":["I need a doctor."],"gr":["Χρειάζομαι γιατρό."],"phon":["Hreiazomai yatro."],"notes":"χρειάζομαι (mid-voice) + γιατρό (acc. of ο γιατρός).","tags":["emergency","medical"]},
    {"id":"e-police","category":"everyday_situations","difficulty":5,"concept":"Emergency — Call the police","en":["Call the police!"],"gr":["Καλέστε την αστυνομία!"],"phon":["Kaleste tin astynomia!"],"notes":"Imperative plural of καλώ. αστυνομία = police.","tags":["emergency"]},
    {"id":"e-lost-pass","category":"everyday_situations","difficulty":5,"concept":"Emergency — I lost my passport","en":["I lost my passport."],"gr":["Έχασα το διαβατήριό μου."],"phon":["Ehasa to diavatirio mou."],"notes":"Aorist of χάνω = lose.","tags":["emergency","travel"]},
    {"id":"e-allergic","category":"everyday_situations","difficulty":5,"concept":"Emergency — I'm allergic to…","en":["I'm allergic to…"],"gr":["Είμαι αλλεργικός σε…"],"phon":["Eimai allergikos se…"],"notes":"Feminine form: αλλεργική. σε + accusative.","tags":["emergency","medical"]},

    {"id":"o-yes","category":"odds_and_ends","difficulty":1,"concept":"Function — yes","en":["yes"],"gr":["ναι"],"phon":["nai"],"notes":"WATCH OUT: looks like English 'nay' (no) but means YES.","tags":["function","yes-no"]},
    {"id":"o-no","category":"odds_and_ends","difficulty":1,"concept":"Function — no","en":["no"],"gr":["όχι"],"phon":["ohi"],"notes":"Often paired with a slight upward head-tilt.","tags":["function","yes-no"]},
    {"id":"o-ok","category":"odds_and_ends","difficulty":1,"concept":"Function — ok / alright","en":["ok / alright"],"gr":["εντάξει"],"phon":["entaxei"],"notes":"Often shortened to ντάξει in speech.","tags":["function","yes-no"]},
    {"id":"o-alpha-01","category":"odds_and_ends","difficulty":1,"concept":"Alphabet — Α α (alpha)","en":["alpha (a)"],"gr":["Α α"],"phon":["alpha"],"notes":"Letter 1. Sound: 'a' as in 'father'.","tags":["alphabet"]},
    {"id":"o-alpha-02","category":"odds_and_ends","difficulty":1,"concept":"Alphabet — Β β (vita)","en":["vita / beta (v)"],"gr":["Β β"],"phon":["vita"],"notes":"Letter 2. Sound: 'v' NOT 'b'.","tags":["alphabet"]},
    {"id":"o-alpha-03","category":"odds_and_ends","difficulty":1,"concept":"Alphabet — Γ γ (gamma)","en":["gamma (g/y)"],"gr":["Γ γ"],"phon":["gamma"],"notes":"Letter 3. Soft 'g' or 'y' before e/i.","tags":["alphabet"]},
    {"id":"o-alpha-04","category":"odds_and_ends","difficulty":1,"concept":"Alphabet — Δ δ (delta)","en":["delta (th in 'this')"],"gr":["Δ δ"],"phon":["delta"],"notes":"Letter 4. Voiced 'th' as in 'this'.","tags":["alphabet"]},
    {"id":"o-alpha-05","category":"odds_and_ends","difficulty":1,"concept":"Alphabet — Ε ε (epsilon)","en":["epsilon (e)"],"gr":["Ε ε"],"phon":["epsilon"],"notes":"Letter 5. Short 'e' as in 'pet'.","tags":["alphabet"]},
    {"id":"o-alpha-06","category":"odds_and_ends","difficulty":1,"concept":"Alphabet — Ζ ζ (zita)","en":["zita / zeta (z)"],"gr":["Ζ ζ"],"phon":["zita"],"notes":"Letter 6.","tags":["alphabet"]},
    {"id":"o-alpha-07","category":"odds_and_ends","difficulty":1,"concept":"Alphabet — Η η (ita)","en":["ita / eta (i)"],"gr":["Η η"],"phon":["ita"],"notes":"Letter 7. Long 'i'. Same sound as Ι and Υ.","tags":["alphabet"]},

    {"id":"o-alpha-08","category":"odds_and_ends","difficulty":2,"concept":"Alphabet — Θ θ (thita)","en":["thita / theta (th in 'think')"],"gr":["Θ θ"],"phon":["thita"],"notes":"Letter 8. Unvoiced 'th' as in 'think' — different from Δ!","tags":["alphabet"]},
    {"id":"o-alpha-09","category":"odds_and_ends","difficulty":2,"concept":"Alphabet — Ι ι (yota)","en":["yota / iota (i)"],"gr":["Ι ι"],"phon":["yota"],"notes":"Letter 9. Short 'i'.","tags":["alphabet"]},
    {"id":"o-alpha-10","category":"odds_and_ends","difficulty":2,"concept":"Alphabet — Κ κ (kappa)","en":["kappa (k)"],"gr":["Κ κ"],"phon":["kappa"],"notes":"Letter 10.","tags":["alphabet"]},
    {"id":"o-alpha-11","category":"odds_and_ends","difficulty":2,"concept":"Alphabet — Λ λ (lamda)","en":["lamda / lambda (l)"],"gr":["Λ λ"],"phon":["lamda"],"notes":"Letter 11.","tags":["alphabet"]},
    {"id":"o-alpha-12","category":"odds_and_ends","difficulty":2,"concept":"Alphabet — Μ μ (mi)","en":["mi / mu (m)"],"gr":["Μ μ"],"phon":["mi"],"notes":"Letter 12.","tags":["alphabet"]},
    {"id":"o-alpha-13","category":"odds_and_ends","difficulty":2,"concept":"Alphabet — Ν ν (ni)","en":["ni / nu (n)"],"gr":["Ν ν"],"phon":["ni"],"notes":"Letter 13.","tags":["alphabet"]},
    {"id":"o-alpha-14","category":"odds_and_ends","difficulty":2,"concept":"Alphabet — Ξ ξ (ksi)","en":["ksi / xi (x or ks)"],"gr":["Ξ ξ"],"phon":["ksi"],"notes":"Letter 14. Single letter for 'ks' sound.","tags":["alphabet"]},
    {"id":"o-num-1","category":"odds_and_ends","difficulty":2,"concept":"Number — 1","en":["one (1)"],"gr":["ένα"],"phon":["ena"],"notes":"Gender forms: ένας (m.) / μία (f.) / ένα (n.).","tags":["numbers"]},
    {"id":"o-num-2","category":"odds_and_ends","difficulty":2,"concept":"Number — 2","en":["two (2)"],"gr":["δύο"],"phon":["dyo"],"notes":"Same form for all genders.","tags":["numbers"]},
    {"id":"o-num-3","category":"odds_and_ends","difficulty":2,"concept":"Number — 3","en":["three (3)"],"gr":["τρία"],"phon":["tria"],"notes":"Gender: τρεις (m./f.) / τρία (n.).","tags":["numbers"]},

    {"id":"o-alpha-15","category":"odds_and_ends","difficulty":3,"concept":"Alphabet — Ο ο (omicron)","en":["omicron (o)"],"gr":["Ο ο"],"phon":["omicron"],"notes":"Letter 15. Short 'o'. Same sound as Ω.","tags":["alphabet"]},
    {"id":"o-alpha-16","category":"odds_and_ends","difficulty":3,"concept":"Alphabet — Π π (pi)","en":["pi (p)"],"gr":["Π π"],"phon":["pi"],"notes":"Letter 16.","tags":["alphabet"]},
    {"id":"o-alpha-17","category":"odds_and_ends","difficulty":3,"concept":"Alphabet — Ρ ρ (ro)","en":["ro / rho (r)"],"gr":["Ρ ρ"],"phon":["ro"],"notes":"Letter 17. Slightly rolled 'r'.","tags":["alphabet"]},
    {"id":"o-alpha-18","category":"odds_and_ends","difficulty":3,"concept":"Alphabet — Σ σ ς (sigma)","en":["sigma (s)"],"gr":["Σ σ ς"],"phon":["sigma"],"notes":"Letter 18. ς is end-of-word form.","tags":["alphabet"]},
    {"id":"o-alpha-19","category":"odds_and_ends","difficulty":3,"concept":"Alphabet — Τ τ (taf)","en":["taf / tau (t)"],"gr":["Τ τ"],"phon":["taf"],"notes":"Letter 19.","tags":["alphabet"]},
    {"id":"o-alpha-20","category":"odds_and_ends","difficulty":3,"concept":"Alphabet — Υ υ (ipsilon)","en":["ipsilon / upsilon (i)"],"gr":["Υ υ"],"phon":["ipsilon"],"notes":"Letter 20. Same sound as Η and Ι.","tags":["alphabet"]},
    {"id":"o-alpha-21","category":"odds_and_ends","difficulty":3,"concept":"Alphabet — Φ φ (fi)","en":["fi / phi (f)"],"gr":["Φ φ"],"phon":["fi"],"notes":"Letter 21.","tags":["alphabet"]},
    {"id":"o-num-4","category":"odds_and_ends","difficulty":3,"concept":"Number — 4","en":["four (4)"],"gr":["τέσσερα"],"phon":["tessera"],"notes":"Gender: τέσσερις (m./f.) / τέσσερα (n.).","tags":["numbers"]},
    {"id":"o-num-5","category":"odds_and_ends","difficulty":3,"concept":"Number — 5","en":["five (5)"],"gr":["πέντε"],"phon":["pente"],"notes":"Same form all genders.","tags":["numbers"]},
    {"id":"o-num-6","category":"odds_and_ends","difficulty":3,"concept":"Number — 6","en":["six (6)"],"gr":["έξι"],"phon":["exi"],"notes":"Same form all genders.","tags":["numbers"]},

    {"id":"o-alpha-22","category":"odds_and_ends","difficulty":4,"concept":"Alphabet — Χ χ (hi)","en":["hi / chi (h)"],"gr":["Χ χ"],"phon":["hi"],"notes":"Letter 22. Rough 'h' like German 'ch' or Spanish 'j'.","tags":["alphabet"]},
    {"id":"o-alpha-23","category":"odds_and_ends","difficulty":4,"concept":"Alphabet — Ψ ψ (psi)","en":["psi (ps)"],"gr":["Ψ ψ"],"phon":["psi"],"notes":"Letter 23. Single letter for 'ps' sound.","tags":["alphabet"]},
    {"id":"o-alpha-24","category":"odds_and_ends","difficulty":4,"concept":"Alphabet — Ω ω (omega)","en":["omega (o)"],"gr":["Ω ω"],"phon":["omega"],"notes":"Letter 24, the last. Same sound as Ο.","tags":["alphabet"]},
    {"id":"o-num-7","category":"odds_and_ends","difficulty":4,"concept":"Number — 7","en":["seven (7)"],"gr":["επτά"],"phon":["epta"],"notes":"Also εφτά in colloquial.","tags":["numbers"]},
    {"id":"o-num-8","category":"odds_and_ends","difficulty":4,"concept":"Number — 8","en":["eight (8)"],"gr":["οκτώ"],"phon":["okto"],"notes":"Also οχτώ in colloquial.","tags":["numbers"]},

    {"id":"o-num-9","category":"odds_and_ends","difficulty":5,"concept":"Number — 9","en":["nine (9)"],"gr":["εννέα"],"phon":["ennea"],"notes":"Also εννιά in colloquial.","tags":["numbers"]},
    {"id":"o-num-10","category":"odds_and_ends","difficulty":5,"concept":"Number — 10","en":["ten (10)"],"gr":["δέκα"],"phon":["deka"],"notes":"Base of decimal counting.","tags":["numbers"]},
    {"id":"o-and","category":"odds_and_ends","difficulty":5,"concept":"Connector — and","en":["and"],"gr":["και"],"phon":["kai"],"notes":"και is used constantly. Often elides before a vowel: κι αυτός.","tags":["connector"]},
    {"id":"o-but","category":"odds_and_ends","difficulty":5,"concept":"Connector — but","en":["but"],"gr":["αλλά"],"phon":["alla"],"notes":"αλλά = but. Contrast μα = but (more conversational).","tags":["connector"]},
    {"id":"o-also","category":"odds_and_ends","difficulty":5,"concept":"Connector — also / too","en":["also / too"],"gr":["επίσης"],"phon":["episis"],"notes":"επίσης = likewise / also.","tags":["connector"]}
  ]
