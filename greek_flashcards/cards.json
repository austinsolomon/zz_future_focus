  "cards": [
    {"id":"verbs-001","category":"verb_conjugations","subcategories":["present-tense"],"concept":"Verb — Sentence Use (wait)","en":["I wait.","I'm waiting for you here."],"gr":["περιμένω","Σε περιμένω εδώ."],"phon":["perimeno","Se perimeno edo."],"notes":"Present, 1st sg. of περιμένω = to wait. Sentence: Ναι, σε περιμένω εδώ.","tags":["verbs","present-tense","sentence-use","wait"]},
    {"id":"verbs-002","category":"verb_conjugations","subcategories":["present-tense"],"concept":"Verb — Present, 1st sg (have)","en":["I have.","you have","s-he has","we have","you-pl have","they have"],"gr":["έχω","έχεις","έχει","έχουμε","έχετε","έχουν"],"phon":["eho","eheis","ehei","ehoume","ehete","ehoun"],"notes":"Full present paradigm. One of the most common Greek verbs.","tags":["verbs","present-tense","full-paradigm","have"]},
    {"id":"verbs-003","category":"verb_conjugations","subcategories":["present-tense","past-simple","past-continuous"],"concept":"Verb — Tense Flip (eat, 1sg)","en":["I eat.","I ate.","I was eating."],"gr":["τρώω","έφαγα","έτρωγα"],"phon":["troo","efaga","etroga"],"notes":"Present / aorist / imperfect. Stress shifts back in past tenses.","tags":["verbs","tense-flip","eat"]},
    {"id":"verbs-004","category":"verb_conjugations","subcategories":["past-simple"],"concept":"Verb — Identify the Form (pigame)","en":["What is 'pigame' in English?","Form analysis."],"gr":["we went","1st plural past simple (aorist) of πηγαίνω"],"phon":["we went","1pl aorist of piyeno"],"notes":"πάμε = 'we go' (present); πήγαμε = 'we went' (aorist). Stress shifts back.","tags":["verbs","past-simple","identify-form"]},
    {"id":"verbs-005","category":"verb_conjugations","subcategories":["past-continuous"],"concept":"Verb — Past Continuous (read)","en":["I was reading.","I was reading a book when you called me."],"gr":["διάβαζα","Διάβαζα ένα βιβλίο όταν μου τηλεφώνησες."],"phon":["diavaza","Diavaza ena vivlio otan mou tilefonises."],"notes":"Imperfect 1sg of διαβάζω.","tags":["verbs","past-continuous","sentence-use","read"]},
    {"id":"verbs-006","category":"verb_conjugations","subcategories":["present-tense"],"concept":"Verb — Present (to be, 1st sg)","en":["I am.","you (sg.) are","s-he / it is","we are","you (pl.) are","they are"],"gr":["είμαι","είσαι","είναι","είμαστε","είστε","είναι"],"phon":["eimai","eisai","einai","eimaste","eiste","einai"],"notes":"Irregular, medial verb (ends in -μαι). 3rd singular and 3rd plural are identical: είναι.","tags":["verbs","present-tense","to-be","full-paradigm","lesson-1"]},
    {"id":"verbs-007","category":"verb_conjugations","subcategories":["present-tense"],"concept":"Verb — Sentence Use (love you)","en":["I love you.","I love / you love / s-he loves / we love / you-pl love / they love"],"gr":["Σ' αγαπώ.","αγαπώ / αγαπάς / αγαπά / αγαπάμε / αγαπάτε / αγαπούν"],"phon":["S' agapo.","agapo / agapas / agapa / agapame / agapate / agapoun"],"notes":"Class-2 verb (stress on ending). 'Se' (you) elides to Σ' before α.","tags":["verbs","present-tense","sentence-use","love","lesson-1"]},
    {"id":"verbs-008","category":"verb_conjugations","subcategories":["present-tense"],"concept":"Verb — Negation (don't have it)","en":["I don't have it.","Pattern: den + (pronoun) + verb"],"gr":["Δεν το έχω.","Σχήμα: δεν + (αντωνυμία) + ρήμα"],"phon":["Den to eho.","den + (object pronoun) + verb"],"notes":"Δεν negates a verb. Object pronoun 'το' (it) goes between δεν and the verb.","tags":["verbs","present-tense","negation","have","lesson-1"]},
    {"id":"verbs-009","category":"verb_conjugations","subcategories":["present-tense"],"concept":"Verb — Present (stay / live, 1st sg)","en":["I stay / I live.","you stay","s-he stays","we stay","you-pl stay","they stay"],"gr":["μένω","μένεις","μένει","μένουμε","μένετε","μένουν"],"phon":["meno","menis","meni","menoume","menete","menoun"],"notes":"Also means 'to live (in a place)'. e.g., Μένω στην Αθήνα = I live in Athens.","tags":["verbs","present-tense","full-paradigm","stay","lesson-1"]},
    {"id":"verbs-010","category":"verb_conjugations","subcategories":["present-tense"],"concept":"Verb — Present (insist, 1st sg)","en":["I insist.","you insist","s-he insists","we insist","you-pl insist","they insist"],"gr":["επιμένω","επιμένεις","επιμένει","επιμένουμε","επιμένετε","επιμένουν"],"phon":["epimeno","epimeneis","epimenei","epimenoume","epimenete","epimenoun"],"notes":"Built from μένω (stay) + επι- prefix. Same conjugation pattern.","tags":["verbs","present-tense","full-paradigm","insist","lesson-1"]},
    {"id":"verbs-011","category":"verb_conjugations","subcategories":["present-tense"],"concept":"Verb — Sentence Use (what are you doing)","en":["What are you doing right now?","I make / do it."],"gr":["Τι κάνεις τώρα;","Το κάνω."],"phon":["Ti kaneis tora?","To kano."],"notes":"κάνω / κάνεις / κάνει — multi-use verb: 'do', 'make', 'cost'. Πόσο κάνει; = How much?","tags":["verbs","present-tense","sentence-use","do","lesson-1"]},
    {"id":"verbs-012","category":"verb_conjugations","subcategories":["present-tense"],"concept":"Verb — Sentence Use (you don't know me)","en":["You don't know me.","ξέρω / ξέρεις / ξέρει = I/you/s-he know(s)"],"gr":["Δεν με ξέρεις.","ξέρω / ξέρεις / ξέρει"],"phon":["Den me xereis.","xero / xereis / xerei"],"notes":"'με' = object pronoun 'me'. ξ = 'ks' / 'x' sound.","tags":["verbs","present-tense","sentence-use","know","lesson-1"]},
    {"id":"verbs-013","category":"verb_conjugations","subcategories":["present-tense"],"concept":"Verb — Sentence Use (don't want to know)","en":["I don't want to know.","I want you to know.","I want it."],"gr":["Δεν θέλω να ξέρω.","Θέλω να ξέρεις.","Το θέλω."],"phon":["Den thelo na xero.","Thelo na xereis.","To thelo."],"notes":"θέλω + να + verb replaces the missing infinitive in Greek. Paradigm: θέλω / θέλεις / θέλει / θέλουμε / θέλετε / θέλουν.","tags":["verbs","present-tense","sentence-use","want","na-construction","lesson-1"]},
    {"id":"verbs-014","category":"verb_conjugations","subcategories":["present-tense"],"concept":"Verb — Present (go, 1st sg)","en":["I go.","you go","s-he goes","we go","you-pl go","they go"],"gr":["πηγαίνω","πηγαίνεις","πηγαίνει","πηγαίνουμε","πηγαίνετε","πηγαίνουν"],"phon":["piyeno","piyenis","piyenei","piyenoume","piyenete","piyenoun"],"notes":"Short form πάω is also very common in speech.","tags":["verbs","present-tense","full-paradigm","go","lesson-1"]},
    {"id":"verbs-015","category":"verb_conjugations","subcategories":["present-tense","past-simple"],"concept":"Verb — Tense Flip (start)","en":["I start / begin.","I started / began."],"gr":["ξεκινάω","ξεκίνησα"],"phon":["xekinao","xekinisa"],"notes":"Class-2 verb. Aorist pattern: drop -άω, add -ησα.","tags":["verbs","tense-flip","start","lesson-1"]},
    {"id":"verbs-016","category":"verb_conjugations","subcategories":["present-tense"],"concept":"Verb — Recognize (be careful)","en":["I'm careful / I pay attention.","Watch out! (imperative)"],"gr":["προσέχω","Πρόσεξε!"],"phon":["prosexo","Prosexe!"],"notes":"Common imperative Πρόσεξε! = Watch out! / Be careful!","tags":["verbs","present-tense","be-careful","lesson-1"]},
    {"id":"verbs-017","category":"verb_conjugations","subcategories":["present-tense"],"concept":"Verb — Sentence Use (speak)","en":["I speak / talk.","Do you speak Greek?"],"gr":["μιλάω","Μιλάς ελληνικά;"],"phon":["milao","Milas elinika?"],"notes":"μιλάω / μιλάς / μιλάει / μιλάμε / μιλάτε / μιλάνε.","tags":["verbs","present-tense","speak","lesson-1"]},
    {"id":"verbs-018","category":"verb_conjugations","subcategories":["present-tense"],"concept":"Verb — Sentence Use (you see me)","en":["You see me.","I see (1st sg)."],"gr":["Εσύ με βλέπεις.","βλέπω"],"phon":["Esi me vlepis.","vlepo"],"notes":"βλέπω = passive 'see'. κοιτάζω = active 'look at'.","tags":["verbs","present-tense","sentence-use","see","lesson-1"]},
    {"id":"verbs-019","category":"verb_conjugations","subcategories":["present-tense"],"concept":"Verb — Recognize (look at)","en":["I look at / I watch."],"gr":["κοιτάζω"],"phon":["kitazo"],"notes":"Active looking AT, vs. βλέπω which is passive 'see'.","tags":["verbs","present-tense","look","lesson-1"]},
    {"id":"verbs-020","category":"verb_conjugations","subcategories":["present-tense"],"concept":"Verb — Sentence Use (need help)","en":["I need.","I need help."],"gr":["χρειάζομαι","Χρειάζομαι βοήθεια."],"phon":["hreiazomai","Hreiazomai voithia."],"notes":"MID-VOICE verb — ends in -μαι, not -ω.","tags":["verbs","present-tense","need","mid-voice","lesson-1"]},
    {"id":"verbs-021","category":"verb_conjugations","subcategories":["present-tense"],"concept":"Verb — Sentence Use (I like it)","en":["I like it.","I like the coffee.","Pattern: 'to-me it-pleases'"],"gr":["Μου αρέσει.","Μου αρέσει ο καφές.","αρέσει = (it) pleases"],"phon":["Mou aresei.","Mou aresei o kafes.","aresei = (it) pleases"],"notes":"Impersonal. For plural subject: Μου αρέσουν.","tags":["verbs","present-tense","sentence-use","like","impersonal","lesson-1"]},
    {"id":"verbs-022","category":"verb_conjugations","subcategories":["future-tense"],"concept":"Verb — Future (I will be seeing)","en":["I will be seeing (continuous)","I will see (simple)","Pattern: tha + verb"],"gr":["Θα βλέπω","Θα δω","θα + ρήμα"],"phon":["Tha vlepo","Tha do","tha + verb"],"notes":"θα + present stem = continuous future; θα + perfective = simple future.","tags":["verbs","future-tense","tha-marker","lesson-1"]},
    {"id":"verbs-023","category":"verb_conjugations","subcategories":["past-simple"],"concept":"Verb — Past Simple (I started)","en":["I started / began.","Present form for comparison."],"gr":["Ξεκίνησα","ξεκινάω (present)"],"phon":["Xekinisa","xekinao (present)"],"notes":"Aorist 1 sg. Pattern: drop -άω, add -ησα.","tags":["verbs","past-simple","start","lesson-1"]},

    {"id":"nouns-001","category":"noun_declension","subcategories":[],"concept":"Noun — Gender (the friend)","en":["the friend (masc.)"],"gr":["ο φίλος"],"phon":["o filos"],"notes":"Masculine article: ο. Greek: ο φίλος.","tags":["nouns","gender","masculine","friend"]},
    {"id":"nouns-002","category":"noun_declension","subcategories":[],"concept":"Noun — Decline (the house, neut.)","en":["the house","of the house","the house (acc.)","the houses","of the houses","the houses (acc.)"],"gr":["το σπίτι","του σπιτιού","το σπίτι","τα σπίτια","των σπιτιών","τα σπίτια"],"phon":["to spiti","tou spitiou","to spiti","ta spitia","ton spition","ta spitia"],"notes":"Neuter declension: το σπίτι / του σπιτιού / το σπίτι (sg.) · τα σπίτια / των σπιτιών / τα σπίτια (pl.). Neuter nouns in -ι are very common.","tags":["nouns","full-declension","neuter","house"]},
    {"id":"nouns-003","category":"noun_declension","subcategories":[],"concept":"Noun — Identify Case ('ton filo')","en":["What case is 'ton filo' in 'Vlepo ton filo mou'?","I see my friend."],"gr":["accusative (direct object)","Βλέπω τον φίλο μου."],"phon":["accusative (direct object)","Vlepo ton filo mou."],"notes":"Accusative marks the direct object. Nom. ο φίλος → acc. τον φίλο.","tags":["nouns","case","accusative"]},
    {"id":"nouns-004","category":"noun_declension","subcategories":[],"concept":"Noun — Singular → Plural (the woman)","en":["the women","the men (pl.)","the children (pl.)"],"gr":["οι γυναίκες","οι άνδρες","τα παιδιά"],"phon":["i gynaikes","i andres","ta paidia"],"notes":"η γυναίκα → οι γυναίκες · ο άνδρας → οι άνδρες · το παιδί → τα παιδιά. Article changes too.","tags":["nouns","plural"]},
    {"id":"nouns-005","category":"noun_declension","subcategories":[],"concept":"Noun — Gender (the book)","en":["the book (neut.)"],"gr":["το βιβλίο"],"phon":["to vivlio"],"notes":"Neuter article: το. το βιβλίο.","tags":["nouns","gender","neuter","book"]},
    {"id":"nouns-006","category":"noun_declension","subcategories":[],"concept":"Noun — Gender (the coffee)","en":["the coffee (masc.)"],"gr":["ο καφές"],"phon":["o kafes"],"notes":"Masculine article: ο. ο καφές.","tags":["nouns","gender","masculine","coffee"]},
    {"id":"nouns-007","category":"noun_declension","subcategories":[],"concept":"Noun — Gender (the water)","en":["the water (neut.)"],"gr":["το νερό"],"phon":["to nero"],"notes":"Neuter article: το. το νερό.","tags":["nouns","gender","neuter","water"]},
    {"id":"nouns-008","category":"noun_declension","subcategories":[],"concept":"Noun — Gender (the door)","en":["the door (fem.)"],"gr":["η πόρτα"],"phon":["i porta"],"notes":"Feminine article: η. η πόρτα.","tags":["nouns","gender","feminine","door"]},
    {"id":"nouns-009","category":"noun_declension","subcategories":[],"concept":"Noun — Gender (the boy)","en":["the boy (neut.)"],"gr":["το αγόρι"],"phon":["to agori"],"notes":"NEUTER despite referring to a male. Diminutive endings -ι / -άκι usually → neuter.","tags":["nouns","gender","neuter","boy","lesson-1"]},
    {"id":"nouns-010","category":"noun_declension","subcategories":[],"concept":"Noun — Gender (the girl)","en":["the girl (neut.)"],"gr":["το κορίτσι"],"phon":["to koritsi"],"notes":"NEUTER despite referring to a female. Diminutive endings -ι / -άκι usually → neuter.","tags":["nouns","gender","neuter","girl","lesson-1"]},

    {"id":"vocab-001","category":"conversational_vocab","subcategories":[],"concept":"Vocab — Greeting (good morning)","en":["Good morning.","Use until early afternoon."],"gr":["Καλημέρα.","Καλησπέρα is the evening greeting."],"phon":["Kalimera.","Kalispera is evening."],"notes":"Καλημέρα. Switches to Καλησπέρα in afternoon/evening.","tags":["vocab","greetings"]},
    {"id":"vocab-002","category":"conversational_vocab","subcategories":[],"concept":"Vocab — Greeting (good evening)","en":["Good evening.","Used afternoon onwards."],"gr":["Καλησπέρα.","Καλημέρα is morning."],"phon":["Kalispera.","Kalimera is morning."],"notes":"Καλησπέρα.","tags":["vocab","greetings"]},
    {"id":"vocab-003","category":"conversational_vocab","subcategories":[],"concept":"Vocab — Greeting (how are you, informal)","en":["How are you? (informal)","Reply: Fine, you?","Reply: Fine, thanks."],"gr":["Τι κάνεις;","Καλά, εσύ;","Καλά, ευχαριστώ."],"phon":["Ti kaneis?","Kala, esy?","Kala, efharisto."],"notes":"Use Τι κάνετε; for formal/plural.","tags":["vocab","greeting-reply","informal"]},
    {"id":"vocab-004","category":"conversational_vocab","subcategories":[],"concept":"Vocab — Ordering (a coffee, please)","en":["A coffee, please.","More polite: I would like a coffee."],"gr":["Έναν καφέ, παρακαλώ.","Θα ήθελα έναν καφέ."],"phon":["Enan kafe, parakalo.","Tha ithela enan kafe."],"notes":"Use at any café. Second form is more polite.","tags":["vocab","situational","ordering"]},
    {"id":"vocab-005","category":"conversational_vocab","subcategories":[],"concept":"Vocab — Phrase (thank you)","en":["thank you","Thank you very much for the help."],"gr":["ευχαριστώ","Ευχαριστώ πολύ για τη βοήθεια."],"phon":["efharisto","Efharisto poly gia ti voithia."],"notes":"Universal thanks.","tags":["vocab","phrase"]},
    {"id":"vocab-006","category":"conversational_vocab","subcategories":[],"concept":"Vocab — Travel (how much)","en":["How much does it cost?"],"gr":["Πόσο κοστίζει;"],"phon":["Poso kostizei?"],"notes":"Or: Πόσο κάνει; (also common).","tags":["vocab","travel","question"]},
    {"id":"vocab-007","category":"conversational_vocab","subcategories":[],"concept":"Vocab — Travel (where is bathroom)","en":["Where is the bathroom?"],"gr":["Πού είναι η τουαλέτα;"],"phon":["Pou einai i toualeta?"],"notes":"Essential travel phrase.","tags":["vocab","travel","question"]},
    {"id":"vocab-008","category":"conversational_vocab","subcategories":[],"concept":"Vocab — Phrase (Where is...?)","en":["Where is the ___?"],"gr":["Πού είναι ...;"],"phon":["Pou einai ...?"],"notes":"Universal opener. Often shortened in speech to Πού 'ναι;","tags":["vocab","phrase","question","lesson-1"]},
    {"id":"vocab-009","category":"conversational_vocab","subcategories":[],"concept":"Vocab — Loanword (system)","en":["system"],"gr":["σύστημα"],"phon":["systima"],"notes":"English borrowed 'system' directly from σύστημα.","tags":["vocab","loanword","lesson-1"]},
    {"id":"vocab-010","category":"conversational_vocab","subcategories":[],"concept":"Vocab — Loanword (category)","en":["category"],"gr":["κατηγορία"],"phon":["katigoria"],"notes":"English 'category' is a direct Greek loanword.","tags":["vocab","loanword","lesson-1"]},
    {"id":"vocab-011","category":"conversational_vocab","subcategories":[],"concept":"Vocab — Loanword (city)","en":["city"],"gr":["πόλη"],"phon":["poli"],"notes":"Feminine. Compare 'metropolis' = μητρόπολις ('mother-city').","tags":["vocab","loanword","lesson-1"]},
    {"id":"vocab-012","category":"conversational_vocab","subcategories":[],"concept":"Vocab — Sentence (I'm trying hard)","en":["I'm trying hard, I can do it."],"gr":["Εγώ προσπαθώ δυνατά, μπορώ να το κάνω."],"phon":["Ego prospatho dynata, boro na to kano."],"notes":"prospatho = try, dynata = hard, boro = can.","tags":["vocab","example-sentence","lesson-1"]},

    {"id":"day-mon","category":"conversational_vocab","subcategories":[],"concept":"Day — Monday","en":["Monday"],"gr":["Δευτέρα"],"phon":["Deftera"],"notes":"All 7 days (fem.): Δευτέρα · Τρίτη · Τετάρτη · Πέμπτη · Παρασκευή · Σάββατο · Κυριακή.","tags":["vocab","days","lesson-1"]},
    {"id":"day-tue","category":"conversational_vocab","subcategories":[],"concept":"Day — Tuesday","en":["Tuesday"],"gr":["Τρίτη"],"phon":["Triti"],"notes":"Literally 'third' day.","tags":["vocab","days","lesson-1"]},
    {"id":"day-wed","category":"conversational_vocab","subcategories":[],"concept":"Day — Wednesday","en":["Wednesday"],"gr":["Τετάρτη"],"phon":["Tetarti"],"notes":"Literally 'fourth' day.","tags":["vocab","days","lesson-1"]},
    {"id":"day-thu","category":"conversational_vocab","subcategories":[],"concept":"Day — Thursday","en":["Thursday"],"gr":["Πέμπτη"],"phon":["Pempti"],"notes":"Literally 'fifth' day.","tags":["vocab","days","lesson-1"]},
    {"id":"day-fri","category":"conversational_vocab","subcategories":[],"concept":"Day — Friday","en":["Friday"],"gr":["Παρασκευή"],"phon":["Paraskevi"],"notes":"Means 'preparation' (for Sabbath in early Christian usage).","tags":["vocab","days","lesson-1"]},
    {"id":"day-sat","category":"conversational_vocab","subcategories":[],"concept":"Day — Saturday","en":["Saturday"],"gr":["Σάββατο"],"phon":["Savato"],"notes":"From Hebrew Sabbath.","tags":["vocab","days","lesson-1"]},
    {"id":"day-sun","category":"conversational_vocab","subcategories":[],"concept":"Day — Sunday","en":["Sunday"],"gr":["Κυριακή"],"phon":["Kyriaki"],"notes":"Means 'Lord's (day)' — from Κύριος = Lord.","tags":["vocab","days","lesson-1"]},

    {"id":"num-1","category":"conversational_vocab","subcategories":[],"concept":"Number — 1 (one)","en":["one (1)"],"gr":["ένα"],"phon":["ena"],"notes":"Gender forms: ένας (m.) / μία (f.) / ένα (n.). Counting form: ένα.","tags":["vocab","numbers","lesson-1"]},
    {"id":"num-2","category":"conversational_vocab","subcategories":[],"concept":"Number — 2 (two)","en":["two (2)"],"gr":["δύο"],"phon":["dyo"],"notes":"Same form for all genders.","tags":["vocab","numbers","lesson-1"]},
    {"id":"num-3","category":"conversational_vocab","subcategories":[],"concept":"Number — 3 (three)","en":["three (3)"],"gr":["τρία"],"phon":["tria"],"notes":"Gender: τρεις (m./f.) / τρία (n.). Counting form: τρία.","tags":["vocab","numbers","lesson-1"]},
    {"id":"num-4","category":"conversational_vocab","subcategories":[],"concept":"Number — 4 (four)","en":["four (4)"],"gr":["τέσσερα"],"phon":["tessera"],"notes":"Gender: τέσσερις (m./f.) / τέσσερα (n.).","tags":["vocab","numbers","lesson-1"]},
    {"id":"num-5","category":"conversational_vocab","subcategories":[],"concept":"Number — 5 (five)","en":["five (5)"],"gr":["πέντε"],"phon":["pente"],"notes":"Same for all genders.","tags":["vocab","numbers","lesson-1"]},
    {"id":"num-6","category":"conversational_vocab","subcategories":[],"concept":"Number — 6 (six)","en":["six (6)"],"gr":["έξι"],"phon":["exi"],"notes":"Same for all genders.","tags":["vocab","numbers","lesson-1"]},
    {"id":"num-7","category":"conversational_vocab","subcategories":[],"concept":"Number — 7 (seven)","en":["seven (7)"],"gr":["επτά"],"phon":["epta"],"notes":"Also written εφτά in colloquial.","tags":["vocab","numbers","lesson-1"]},
    {"id":"num-8","category":"conversational_vocab","subcategories":[],"concept":"Number — 8 (eight)","en":["eight (8)"],"gr":["οκτώ"],"phon":["okto"],"notes":"Also written οχτώ in colloquial.","tags":["vocab","numbers","lesson-1"]},
    {"id":"num-9","category":"conversational_vocab","subcategories":[],"concept":"Number — 9 (nine)","en":["nine (9)"],"gr":["εννέα"],"phon":["ennea"],"notes":"Also εννιά in colloquial.","tags":["vocab","numbers","lesson-1"]},
    {"id":"num-10","category":"conversational_vocab","subcategories":[],"concept":"Number — 10 (ten)","en":["ten (10)"],"gr":["δέκα"],"phon":["deka"],"notes":"Base of decimal counting.","tags":["vocab","numbers","lesson-1"]},

    {"id":"fw-where","category":"function_words","subcategories":[],"concept":"Function — where?","en":["where?"],"gr":["πού"],"phon":["pou"],"notes":"πού einai? = where is...?","tags":["function-words","question","lesson-1"]},
    {"id":"fw-why","category":"function_words","subcategories":[],"concept":"Function — why? / for what?","en":["why? / for what?"],"gr":["γιατί"],"phon":["ya ti"],"notes":"Also means 'because' in answer form.","tags":["function-words","question","lesson-1"]},
