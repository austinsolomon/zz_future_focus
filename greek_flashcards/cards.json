    {"id":"n-tea","category":"noun_declension","difficulty":2,"concept":"Noun — the tea (n.)","en":["the tea (n.)"],"gr":["το τσάι"],"phon":["to tsai"],"notes":"Neuter.","tags":["nouns","gender","neuter"]},
    {"id":"n-beer","category":"noun_declension","difficulty":2,"concept":"Noun — the beer (f.)","en":["the beer (f.)"],"gr":["η μπίρα"],"phon":["i bira"],"notes":"Feminine. μπ = 'b' sound.","tags":["nouns","gender","feminine"]},
    {"id":"n-table","category":"noun_declension","difficulty":2,"concept":"Noun — the table (n.)","en":["the table (n.)"],"gr":["το τραπέζι"],"phon":["to trapezi"],"notes":"Neuter. Also means restaurant table.","tags":["nouns","gender","neuter"]},
    {"id":"n-street","category":"noun_declension","difficulty":2,"concept":"Noun — the road / street (m.)","en":["the road / street (m.)"],"gr":["ο δρόμος"],"phon":["o dromos"],"notes":"Masculine. Origin of English 'aerodrome' / 'hippodrome'.","tags":["nouns","gender","masculine"]},

    {"id":"n-women-pl","category":"noun_declension","difficulty":3,"concept":"Noun — the women (pl.)","en":["the women (plural)"],"gr":["οι γυναίκες"],"phon":["i gynaikes"],"notes":"Singular η γυναίκα → plural οι γυναίκες. Article η → οι.","tags":["nouns","plural","feminine"]},
    {"id":"n-men-pl","category":"noun_declension","difficulty":3,"concept":"Noun — the men (pl.)","en":["the men (plural)"],"gr":["οι άνδρες"],"phon":["i andres"],"notes":"Singular ο άνδρας → plural οι άνδρες. Article ο → οι.","tags":["nouns","plural","masculine"]},
