    {"id":"v-go","category":"verb_conjugations","difficulty":1,"concept":"Verb — I go","en":["I go."],"gr":["πηγαίνω"],"phon":["piyeno"],"notes":"πηγαίνω. Short form πάω is also common.","tags":["verbs","present","go"]},
    {"id":"v-see","category":"verb_conjugations","difficulty":1,"concept":"Verb — I see","en":["I see."],"gr":["βλέπω"],"phon":["vlepo"],"notes":"βλέπω = passive 'see'. κοιτάζω = active 'look at'.","tags":["verbs","present","see"]},
    {"id":"v-eat","category":"verb_conjugations","difficulty":1,"concept":"Verb — I eat","en":["I eat."],"gr":["τρώω"],"phon":["troo"],"notes":"τρώω. Paradigm: τρώω, τρως, τρώει, τρώμε, τρώτε, τρώνε.","tags":["verbs","present","eat"]},
    {"id":"v-drink","category":"verb_conjugations","difficulty":1,"concept":"Verb — I drink","en":["I drink."],"gr":["πίνω"],"phon":["pino"],"notes":"πίνω. Paradigm: πίνω, πίνεις, πίνει, πίνουμε, πίνετε, πίνουν.","tags":["verbs","present","drink"]},
    {"id":"v-sleep","category":"verb_conjugations","difficulty":1,"concept":"Verb — I sleep","en":["I sleep."],"gr":["κοιμάμαι"],"phon":["koimamai"],"notes":"κοιμάμαι. MID-VOICE (ends in -μαι).","tags":["verbs","present","sleep","mid-voice"]},
    {"id":"v-wait","category":"verb_conjugations","difficulty":1,"concept":"Verb — I wait","en":["I wait."],"gr":["περιμένω"],"phon":["perimeno"],"notes":"περιμένω. Example: Σε περιμένω εδώ (I'm waiting for you here).","tags":["verbs","present","wait"]},
    {"id":"v-speak","category":"verb_conjugations","difficulty":1,"concept":"Verb — I speak","en":["I speak."],"gr":["μιλάω"],"phon":["milao"],"notes":"μιλάω / μιλώ. Class-2 verb. Μιλάς ελληνικά; = Do you speak Greek?","tags":["verbs","present","speak"]},

    {"id":"v-stay","category":"verb_conjugations","difficulty":2,"concept":"Verb — I stay / I live","en":["I stay / I live."],"gr":["μένω"],"phon":["meno"],"notes":"μένω. Also 'live (in a place)'. Μένω στην Αθήνα = I live in Athens.","tags":["verbs","present","stay","live"]},
    {"id":"v-read","category":"verb_conjugations","difficulty":2,"concept":"Verb — I read","en":["I read."],"gr":["διαβάζω"],"phon":["diavazo"],"notes":"διαβάζω. Past simple: διάβασα. Past continuous: διάβαζα.","tags":["verbs","present","read"]},
    {"id":"v-write","category":"verb_conjugations","difficulty":2,"concept":"Verb — I write","en":["I write."],"gr":["γράφω"],"phon":["grafo"],"notes":"γράφω. Past simple: έγραψα.","tags":["verbs","present","write"]},
    {"id":"v-work","category":"verb_conjugations","difficulty":2,"concept":"Verb — I work","en":["I work."],"gr":["δουλεύω"],"phon":["doulevo"],"notes":"δουλεύω. δουλειά = work (noun).","tags":["verbs","present","work"]},
    {"id":"v-do","category":"verb_conjugations","difficulty":2,"concept":"Verb — What are you doing?","en":["What are you doing?"],"gr":["Τι κάνεις;"],"phon":["Ti kaneis?"],"notes":"κάνω = do / make / cost. Πόσο κάνει; = How much?","tags":["verbs","present","do","question"]},
    {"id":"v-love","category":"verb_conjugations","difficulty":2,"concept":"Verb — I love you","en":["I love you."],"gr":["Σ' αγαπώ."],"phon":["S' agapo."],"notes":"αγαπώ. Class-2 verb. 'Se' elides to Σ' before α.","tags":["verbs","present","love","sentence"]},
    {"id":"v-look","category":"verb_conjugations","difficulty":2,"concept":"Verb — I look at / I watch","en":["I look at / I watch."],"gr":["κοιτάζω"],"phon":["kitazo"],"notes":"κοιτάζω = active 'look at'. βλέπω = passive 'see'.","tags":["verbs","present","look"]},
    {"id":"v-careful","category":"verb_conjugations","difficulty":2,"concept":"Verb — I'm careful / pay attention","en":["I'm careful / I pay attention."],"gr":["προσέχω"],"phon":["prosexo"],"notes":"προσέχω. Imperative: Πρόσεξε! = Watch out!","tags":["verbs","present","careful"]},
    {"id":"v-need","category":"verb_conjugations","difficulty":2,"concept":"Verb — I need","en":["I need."],"gr":["χρειάζομαι"],"phon":["hreiazomai"],"notes":"χρειάζομαι. MID-VOICE verb. Χρειάζομαι βοήθεια = I need help.","tags":["verbs","present","need","mid-voice"]},
    {"id":"v-insist","category":"verb_conjugations","difficulty":2,"concept":"Verb — I insist","en":["I insist."],"gr":["επιμένω"],"phon":["epimeno"],"notes":"επιμένω. Built from μένω + επι- prefix.","tags":["verbs","present","insist"]},

    {"id":"v-have-neg","category":"verb_conjugations","difficulty":3,"concept":"Verb — I don't have it","en":["I don't have it."],"gr":["Δεν το έχω."],"phon":["Den to eho."],"notes":"Pattern: δεν + (pronoun) + verb. το = it (acc.).","tags":["verbs","present","negation"]},
    {"id":"v-know-neg","category":"verb_conjugations","difficulty":3,"concept":"Verb — You don't know me","en":["You don't know me."],"gr":["Δεν με ξέρεις."],"phon":["Den me xereis."],"notes":"με = me (object pronoun). ξέρω/ξέρεις/ξέρει.","tags":["verbs","present","negation","know"]},
    {"id":"v-eat-tense","category":"verb_conjugations","difficulty":3,"concept":"Verb — I ate (past simple)","en":["I ate."],"gr":["έφαγα"],"phon":["efaga"],"notes":"Aorist 1sg of τρώω. Present: τρώω; past continuous: έτρωγα.","tags":["verbs","past-simple","eat"]},
    {"id":"v-was-reading","category":"verb_conjugations","difficulty":3,"concept":"Verb — I was reading","en":["I was reading."],"gr":["διάβαζα"],"phon":["diavaza"],"notes":"Imperfect (past continuous) 1sg of διαβάζω. Example: Διάβαζα ένα βιβλίο όταν μου τηλεφώνησες.","tags":["verbs","past-continuous","read"]},
    {"id":"v-want-na","category":"verb_conjugations","difficulty":3,"concept":"Verb — I don't want to know","en":["I don't want to know."],"gr":["Δεν θέλω να ξέρω."],"phon":["Den thelo na xero."],"notes":"θέλω + να + verb replaces the missing infinitive. Literally: 'I-don't-want that I-know'.","tags":["verbs","present","na-construction"]},
    {"id":"v-like","category":"verb_conjugations","difficulty":3,"concept":"Verb — I like it (impersonal)","en":["I like it."],"gr":["Μου αρέσει."],"phon":["Mou aresei."],"notes":"Impersonal: literally 'to-me it-pleases'. For plural subject: Μου αρέσουν.","tags":["verbs","present","impersonal","like"]},
    {"id":"v-started","category":"verb_conjugations","difficulty":3,"concept":"Verb — I started","en":["I started."],"gr":["Ξεκίνησα"],"phon":["Xekinisa"],"notes":"Aorist 1sg of ξεκινάω. Pattern: drop -άω, add -ησα.","tags":["verbs","past-simple","start"]},
    {"id":"v-bought","category":"verb_conjugations","difficulty":3,"concept":"Verb — I bought","en":["I bought."],"gr":["αγόρασα"],"phon":["agorasa"],"notes":"Aorist of αγοράζω = to buy.","tags":["verbs","past-simple","buy"]},
    {"id":"v-gave","category":"verb_conjugations","difficulty":3,"concept":"Verb — I gave","en":["I gave."],"gr":["έδωσα"],"phon":["edosa"],"notes":"Aorist of δίνω = to give.","tags":["verbs","past-simple","give"]},
    {"id":"v-saw-me","category":"verb_conjugations","difficulty":3,"concept":"Verb — You see me","en":["You see me."],"gr":["Εσύ με βλέπεις."],"phon":["Esi me vlepis."],"notes":"Εσύ = you (emphatic). με = me (object pronoun).","tags":["verbs","present","sentence","see"]},

    {"id":"v-future","category":"verb_conjugations","difficulty":4,"concept":"Verb — I will be seeing","en":["I will be seeing."],"gr":["Θα βλέπω"],"phon":["Tha vlepo"],"notes":"θα + present stem = continuous future. θα + perfective stem = simple future (Θα δω).","tags":["verbs","future"]},
    {"id":"v-had","category":"verb_conjugations","difficulty":4,"concept":"Verb — I had","en":["I had."],"gr":["είχα"],"phon":["eiha"],"notes":"Past simple of έχω. Paradigm: είχα, είχες, είχε, είχαμε, είχατε, είχαν.","tags":["verbs","past-simple","have"]},
    {"id":"v-was","category":"verb_conjugations","difficulty":4,"concept":"Verb — I was","en":["I was."],"gr":["ήμουν"],"phon":["imoun"],"notes":"Past of είμαι. Paradigm: ήμουν, ήσουν, ήταν, ήμασταν, ήσασταν, ήταν.","tags":["verbs","past-simple","to-be"]},
    {"id":"v-would-like","category":"verb_conjugations","difficulty":4,"concept":"Verb — I would like…","en":["I would like…"],"gr":["Θα ήθελα…"],"phon":["Tha ithela…"],"notes":"Polite request. θα + ήθελα (past of θέλω, used as conditional). Θα ήθελα έναν καφέ = I'd like a coffee.","tags":["verbs","conditional","polite"]},
    {"id":"v-can-help","category":"verb_conjugations","difficulty":4,"concept":"Verb — Can you help me?","en":["Can you help me?"],"gr":["Μπορείς να με βοηθήσεις;"],"phon":["Boreis na me voithiseis?"],"notes":"μπορώ = can. βοηθάω = help. Pattern: μπορώ + να + verb.","tags":["verbs","present","question","na-construction"]},
    {"id":"v-no-understand","category":"verb_conjugations","difficulty":4,"concept":"Verb — I don't understand","en":["I don't understand."],"gr":["Δεν καταλαβαίνω."],"phon":["Den katalaveno."],"notes":"καταλαβαίνω = understand. Universally useful tourist phrase.","tags":["verbs","present","negation"]},

    {"id":"v-finished","category":"verb_conjugations","difficulty":5,"concept":"Verb — I have finished","en":["I have finished."],"gr":["Έχω τελειώσει."],"phon":["Eho teleiosei."],"notes":"PERFECT TENSE: έχω + perfective infinitive form (-ει). Means completed action with present relevance.","tags":["verbs","perfect"]},
    {"id":"v-if-were","category":"verb_conjugations","difficulty":5,"concept":"Verb — If I were you…","en":["If I were you…"],"gr":["Αν ήμουν εσύ…"],"phon":["An imoun esi…"],"notes":"Counterfactual conditional. Αν + past = hypothetical.","tags":["verbs","conditional","subjunctive"]},
    {"id":"v-mind-business","category":"verb_conjugations","difficulty":5,"concept":"Verb — Mind your own business","en":["Mind your own business."],"gr":["Κοίτα τη δουλειά σου."],"phon":["Koita ti douleia sou."],"notes":"Idiom. Lit. 'Look at your work.' Imperative of κοιτάω.","tags":["verbs","idiom","imperative"]},
    {"id":"v-well-see","category":"verb_conjugations","difficulty":5,"concept":"Verb — We'll see","en":["We'll see."],"gr":["Θα δούμε."],"phon":["Tha doume."],"notes":"Common future expression. θα + δούμε (perfective 1pl of βλέπω).","tags":["verbs","future","idiom"]},
    {"id":"v-id-pigame","category":"verb_conjugations","difficulty":5,"concept":"Verb — What is 'pigame'?","en":["What is 'pigame' in English?"],"gr":["we went"],"phon":["we went"],"notes":"πήγαμε = 1st plural aorist (past simple) of πηγαίνω. Stress shifts back in aorist.","tags":["verbs","past-simple","identify"]},

