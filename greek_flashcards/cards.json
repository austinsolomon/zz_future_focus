    {"id":"n-water","category":"noun_declension","difficulty":1,"concept":"Noun — the water (n.)","en":["the water (n.)"],"gr":["το νερό"],"phon":["to nero"],"notes":"Neuter. το νερό.","tags":["nouns","gender","neuter"]},
    {"id":"n-door","category":"noun_declension","difficulty":1,"concept":"Noun — the door (f.)","en":["the door (f.)"],"gr":["η πόρτα"],"phon":["i porta"],"notes":"Feminine article: η. η πόρτα.","tags":["nouns","gender","feminine"]},
