    {"id":"n-school","category":"noun_declension","difficulty":2,"concept":"Noun — the school (n.)","en":["the school (n.)"],"gr":["το σχολείο"],"phon":["to scholeio"],"notes":"Neuter. Greek 'school' = origin of English word.","tags":["nouns","gender","neuter"]},
