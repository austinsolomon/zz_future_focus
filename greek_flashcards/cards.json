    {"id":"n-woman","category":"noun_declension","difficulty":2,"concept":"Noun — the woman (f.)","en":["the woman (f.)"],"gr":["η γυναίκα"],"phon":["i gynaika"],"notes":"Feminine. Plural: οι γυναίκες.","tags":["nouns","gender","feminine"]},
