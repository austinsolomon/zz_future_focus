    {"id":"n-books-pl","category":"noun_declension","difficulty":3,"concept":"Noun — the books (pl.)","en":["the books (plural)"],"gr":["τα βιβλία"],"phon":["ta vivlia"],"notes":"το βιβλίο → τα βιβλία.","tags":["nouns","plural","neuter"]},
    {"id":"n-houses-pl","category":"noun_declension","difficulty":3,"concept":"Noun — the houses (pl.)","en":["the houses (plural)"],"gr":["τα σπίτια"],"phon":["ta spitia"],"notes":"το σπίτι → τα σπίτια.","tags":["nouns","plural","neuter"]},
    {"id":"n-see-friend","category":"noun_declension","difficulty":3,"concept":"Noun — I see the friend (acc.)","en":["I see the friend."],"gr":["Βλέπω τον φίλο."],"phon":["Vlepo ton filo."],"notes":"Accusative (direct object). Nom ο φίλος → acc τον φίλο.","tags":["nouns","case","accusative"]},
    {"id":"n-of-house","category":"noun_declension","difficulty":3,"concept":"Noun — of the house (gen.)","en":["of the house"],"gr":["του σπιτιού"],"phon":["tou spitiou"],"notes":"Genitive singular of το σπίτι. Used for possession: το κλειδί του σπιτιού = the house key.","tags":["nouns","case","genitive"]},
    {"id":"n-of-friend","category":"noun_declension","difficulty":3,"concept":"Noun — of the friend (gen.)","en":["of the friend"],"gr":["του φίλου"],"phon":["tou filou"],"notes":"Genitive singular of ο φίλος.","tags":["nouns","case","genitive"]},
    {"id":"n-to-school","category":"noun_declension","difficulty":3,"concept":"Noun — to school (prep + acc.)","en":["to school / at school"],"gr":["στο σχολείο"],"phon":["sto scholeio"],"notes":"σε + το → στο. σε requires accusative case.","tags":["nouns","case","accusative","preposition"]},
    {"id":"n-id-case","category":"noun_declension","difficulty":3,"concept":"Noun — Identify case ('ton filo')","en":["What case is 'ton filo' in 'Vlepo ton filo mou'?"],"gr":["accusative (direct object)"],"phon":["accusative (direct object)"],"notes":"βλέπω takes a direct object → accusative. ο φίλος → τον φίλο.","tags":["nouns","case","identify"]},

