{
  "name": "BR2 Inbox PARA Triage - Tier 2 Toy Example",
  "nodes": [
    {
      "parameters": {
        "pollTimes": {
          "item": [
            {
              "mode": "everyMinute"
            }
          ]
        },
        "filters": {
          "customData": [
            {
              "key": "is:unread",
              "value": "true"
            },
            {
              "key": "label",
              "value": "inbox"
            }
          ]
        }
      },
      "name": "Gmail Trigger: New Inbox Item",
      "type": "n8n-nodes-base.gmailTrigger",
      "typeVersion": 1,
      "position": [250, 300],
      "credentials": {
        "gmailOAuth2": {
          "id": "1",
          "name": "Gmail OAuth2"
        }
      },
      "id": "tier2_br2_trigger",
      "notes": "TIER 2 CHARACTERISTIC: Event-based trigger - responds to new emails/items in inbox"
    },
    {
      "parameters": {
        "jsCode": "// TIER 2: Extract inbox item data\nconst item = $input.first().json;\n\nreturn [{\n  json: {\n    from: item.from || '',\n    subject: item.subject || '',\n    body: item.textPlain || item.textHtml || '',\n    snippet: item.snippet || '',\n    labels: item.labelIds || [],\n    messageId: item.id || '',\n    threadId: item.threadId || '',\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
      "name": "Extract Inbox Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [450, 300],
      "id": "tier2_br2_extract",
      "notes": "TIER 2: Prepare data for AI analysis"
    },
    {
      "parameters": {
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "anthropicApi",
        "requestMethod": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-sonnet-4-5-20250929\",\n  \"max_tokens\": 300,\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Analyze this inbox item and categorize it using the PARA method (Projects, Areas, Resources, Archives). Also determine if it's actionable. Respond with ONLY a JSON object:\\n\\n{\\\"category\\\": \\\"PROJECT|AREA|RESOURCE|ARCHIVE\\\", \\\"subcategory\\\": \\\"specific topic\\\", \\\"is_actionable\\\": true|false, \\\"priority\\\": \\\"HIGH|MEDIUM|LOW\\\", \\\"suggested_action\\\": \\\"brief action\\\" }\\n\\nFrom: {{ $json.from }}\\nSubject: {{ $json.subject }}\\nContent: {{ $json.snippet }}\\n\\nPARA Classification:\"\n    }\n  ]\n}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "name": "Call Claude API: PARA Categorization",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [650, 300],
      "credentials": {
        "anthropicApi": {
          "id": "2",
          "name": "Anthropic API"
        }
      },
      "id": "tier2_br2_claude",
      "notes": "TIER 2 KEY: ONE LLM call adds semantic understanding - PARA categorization based on content meaning"
    },
    {
      "parameters": {
        "jsCode": "// TIER 2: Parse Claude's PARA classification\nconst claudeResponse = $input.first().json;\nconst classificationText = claudeResponse.content[0].text.trim();\n\nlet classification;\ntry {\n  // Try to parse JSON response\n  classification = JSON.parse(classificationText);\n} catch (err) {\n  // Fallback if JSON parsing fails\n  classification = {\n    category: 'RESOURCE',\n    subcategory: 'uncategorized',\n    is_actionable: false,\n    priority: 'LOW',\n    suggested_action: 'Review and categorize manually'\n  };\n}\n\n// Validate category\nconst validCategories = ['PROJECT', 'AREA', 'RESOURCE', 'ARCHIVE'];\nif (!validCategories.includes(classification.category)) {\n  classification.category = 'RESOURCE';\n}\n\n// Get original inbox data\nconst inboxData = $('Extract Inbox Data').first().json;\n\nreturn [{\n  json: {\n    ...inboxData,\n    para: {\n      category: classification.category,\n      subcategory: classification.subcategory || 'general',\n      is_actionable: classification.is_actionable || false,\n      priority: classification.priority || 'MEDIUM',\n      suggested_action: classification.suggested_action || ''\n    },\n    classifiedAt: new Date().toISOString()\n  }\n}];"
      },
      "name": "Parse PARA Classification",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [850, 300],
      "id": "tier2_br2_parse",
      "notes": "TIER 2: Extract structured PARA data from AI response"
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{$json.para.category}}",
              "operation": "equals",
              "value2": "PROJECT"
            }
          ]
        }
      },
      "name": "Route by PARA Category",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 1,
      "position": [1050, 300],
      "id": "tier2_br2_route",
      "notes": "TIER 2 CHARACTERISTIC: Semantic routing based on AI's PARA classification"
    },
    {
      "parameters": {
        "url": "={{$env.OBSIDIAN_API_URL}}/notes/projects",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "title",
              "value": "={{$json.subject}}"
            },
            {
              "name": "content",
              "value": "=# {{$json.subject}}\\n\\n**From:** {{$json.from}}\\n**Date:** {{$json.timestamp}}\\n**Priority:** {{$json.para.priority}}\\n\\n## Action\\n{{$json.para.suggested_action}}\\n\\n## Original Content\\n{{$json.body}}"
            },
            {
              "name": "folder",
              "value": "=Projects/{{$json.para.subcategory}}"
            },
            {
              "name": "tags",
              "value": "=['inbox', 'project', $json.para.subcategory.toLowerCase()]"
            }
          ]
        }
      },
      "name": "Create Project Note",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1250, 200],
      "credentials": {
        "httpHeaderAuth": {
          "id": "3",
          "name": "Obsidian API"
        }
      },
      "id": "tier2_br2_project_note",
      "notes": "TIER 2: Context-aware action - create note in Projects folder with AI-suggested action"
    },
    {
      "parameters": {
        "url": "={{$env.OBSIDIAN_API_URL}}/notes/areas",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
