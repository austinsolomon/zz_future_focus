            },
            {
              "name": "content",
              "value": "=# {{$json.subject}}\\n\\n**From:** {{$json.from}}\\n**Date:** {{$json.timestamp}}\\n\\n## Notes\\n{{$json.body}}"
            },
            {
              "name": "folder",
              "value": "=Areas/{{$json.para.subcategory}}"
            },
            {
              "name": "tags",
              "value": "=['inbox', 'area', $json.para.subcategory.toLowerCase()]"
            }
          ]
        }
      },
      "name": "Create Area Note",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1250, 300],
      "credentials": {
        "httpHeaderAuth": {
          "id": "3",
          "name": "Obsidian API"
        }
      },
      "id": "tier2_br2_area_note",
      "notes": "TIER 2: Create note in Areas folder for ongoing responsibilities"
    },
