      "parameters": {
        "url": "={{$env.OBSIDIAN_API_URL}}/notes/archives",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "title",
              "value": "={{$json.subject}}"
            },
            {
              "name": "content",
              "value": "=# {{$json.subject}}\\n\\n**From:** {{$json.from}}\\n**Date:** {{$json.timestamp}}\\n\\n## Archived\\n{{$json.body}}"
            },
            {
              "name": "folder",
              "value": "=Archives/{{new Date().getFullYear()}}"
            },
            {
              "name": "tags",
              "value": "=['inbox', 'archive']"
            }
          ]
        }
      },
      "name": "Create Archive Note",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1250, 500],
      "credentials": {
        "httpHeaderAuth": {
          "id": "3",
          "name": "Obsidian API"
        }
      },
      "id": "tier2_br2_archive_note",
      "notes": "TIER 2: Archive inactive/completed items"
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{$json.para.is_actionable}}",
              "value2": true
            }
          ]
        }
      },
      "name": "Check if Actionable",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [1450, 300],
      "id": "tier2_br2_actionable_check",
      "notes": "TIER 2: Route actionable items to task manager"
    },
    {
      "parameters": {
        "url": "={{$env.TODOIST_API_URL}}/tasks",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"content\": \"{{ $('Parse PARA Classification').first().json.para.suggested_action }}\",\n  \"description\": \"From: {{ $('Extract Inbox Data').first().json.from }}\\nSubject: {{ $('Extract Inbox Data').first().json.subject }}\",\n  \"priority\": {{ $('Parse PARA Classification').first().json.para.priority === 'HIGH' ? 4 : ($('Parse PARA Classification').first().json.para.priority === 'MEDIUM' ? 3 : 2) }},\n  \"labels\": [\"inbox-triage\", \"{{ $('Parse PARA Classification').first().json.para.category.toLowerCase() }}\"]\n}"
      },
      "name": "Create Task in Todoist",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1650, 200],
      "credentials": {
        "httpHeaderAuth": {
          "id": "4",
          "name": "Todoist API"
        }
      },
      "id": "tier2_br2_create_task",
      "notes": "TIER 2: Create actionable task based on AI analysis"
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "addLabels",
        "messageId": "={{$('Extract Inbox Data').first().json.messageId}}",
        "labelIds": "=['PROCESSED', '{{$('Parse PARA Classification').first().json.para.category}}']"
      },
      "name": "Label Email as Processed",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2,
      "position": [1650, 400],
      "credentials": {
        "gmailOAuth2": {
          "id": "1",
          "name": "Gmail OAuth2"
        }
      },
      "id": "tier2_br2_label_email",
      "notes": "TIER 2: Mark email with PARA category label"
    },
    {
      "parameters": {
        "jsCode": "// TIER 2: Log PARA categorization for analytics\nconst inboxData = $input.first().json;\nconst para = $('Parse PARA Classification').first().json.para;\n\nconst logEntry = {\n  timestamp: new Date().toISOString(),\n  workflow: 'br2_inbox_triage',\n  messageId: inboxData.messageId,\n  from: inboxData.from,\n  subject: inboxData.subject,\n  para_category: para.category,\n  subcategory: para.subcategory,\n  is_actionable: para.is_actionable,\n  priority: para.priority,\n  task_created: para.is_actionable\n};\n\nconsole.log('Inbox item triaged:', logEntry);\n\nconst fs = require('fs');\nconst logPath = process.env.BR2_LOG_PATH || '/tmp/br2_triage.log';\ntry {\n  fs.appendFileSync(logPath, JSON.stringify(logEntry) + '\\n');\n} catch (err) {\n  console.error('Failed to write log:', err);\n}\n\nreturn [{ json: logEntry }];"
      },
      "name": "Log PARA Classification",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1850, 300],
      "id": "tier2_br2_log",
      "notes": "TIER 2: Track AI categorizations for PARA system analytics"
    }
  ],
